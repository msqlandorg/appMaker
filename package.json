{
  "name": "app-editor",
  "version": "1.0.0",
  "description": "Desktop app editor with real-time preview and local AI diagnostics",
  "main": "./out/main/main.js",
  "author": "app-editor",
  "homepage": ".",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win",
    "build:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-updater": "^6.3.9",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^32.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "build": {
    "productName": "AppEditor",
    "appId": "com.appeditor.desktop",
    "electronDist": "node_modules/electron/dist",
    "electronVersion": "32.3.3",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "out",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "App Editor"
    }
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
